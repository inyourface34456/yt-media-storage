{
  "name": "media-storage",
  "version-string": "1.0.0",
  "builtin-baseline": "99a97de2cb371449d4fb9dc970f2ac562d689ec2",
  "dependencies": [
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "avfilter",
        "swscale",
        "swresample",
        "x264"
      ]
    },
    "libsodium"
  ],
  "features": {
    "gui": {
      "description": "Qt GUI dependencies (qtbase). Disable to use system Qt.",
      "dependencies": [
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "gui",
            "widgets",
            "png",
            "freetype",
            "harfbuzz"
          ]
        },
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "fontconfig",
            "xcb",
            "xcb-xlib",
            "xkb",
            "xkbcommon-x11",
            "xrender",
            "xlib"
          ],
          "platform": "linux"
        }
      ]
    }
  }
}
